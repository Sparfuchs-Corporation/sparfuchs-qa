{
  "name": "sparfuchs-qa",
  "version": "1.0.0",
  "private": true,
  "description": "Sparfuchs QA Platform — canaries, scripts, docs, and test fixtures",
  "scripts": {
    "canaries": "tsx canaries/index.ts",
    "qa:quick": "tsx canaries/index.ts",
    "qa:report-push": "tsx scripts/qa-report-adapter.ts",
    "qa:nightly": "tsx scripts/trigger-nightly-regression.ts",
    "qa:seed-baselines": "tsx scripts/seed-ai-baselines.ts",
    "qa:sca": "tsx scripts/package-verify.ts",
    "qa:verify": "tsx scripts/package-verify.ts --dry-run",
    "qa:flaky": "tsx scripts/flaky-test-tracker.ts --report",
    "qa:flaky-track": "tsx scripts/flaky-test-tracker.ts",
    "qa:cred-setup": "tsx lib/credentials/setup-wizard.ts",
    "qa:delta": "tsx scripts/qa-delta-report.ts",
    "qa:evolve-v2": "tsx scripts/qa-evolve-v2.ts",
    "qa:cleanup": "tsx scripts/qa-cleanup.ts",
    "qa:sync": "tsx scripts/qa-firestore-sync.ts"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
